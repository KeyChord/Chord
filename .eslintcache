91","text":"2192"},["2193"],"Expected indentation of 3 tabs but found 6 spaces.",{"range":"2194","text":"2195"},["2196"],{"range":"2197","text":"2195"},["2198"],{"range":"2199","text":"2195"},["2200"],{"range":"2201","text":"2195"},["2202"],{"range":"2203","text":"2195"},["2204"],{"range":"2205","text":"2192"},["2206"],{"range":"2207","text":"2192"},["2208"],{"range":"2209","text":"2195"},["2210"],{"range":"2211","text":"2195"},["2212"],{"range":"2213","text":"2195"},["2214"],{"range":"2215","text":"2195"},["2216"],{"range":"2217","text":"2195"},["2218"],{"range":"2219","text":"2192"},["2220"],{"range":"2221","text":"2192"},["2222"],{"range":"2223","text":"2195"},["2224"],{"range":"2225","text":"2195"},["2226"],{"range":"2227","text":"2195"},["2228"],{"range":"2229","text":"2195"},["2230"],{"range":"2231","text":"2195"},["2232"],{"range":"2233","text":"2192"},["2234"],{"range":"2235","text":"2124"},["2236"],{"range":"2237","text":"2124"},["2238"],"object-shorthand","Expected property shorthand.","expectedPropertyShorthand",{"range":"2239","text":"2240"},["2241"],{"range":"2242","text":"2124"},["2243"],{"range":"2244","text":"2245"},["2246"],{"range":"2247","text":"2124"},["2248"],{"range":"2249","text":"2250"},["2251"],{"range":"2252","text":"2112"},["2253"],{"range":"2254","text":"2124"},["2255"],{"range":"2256","text":"2124"},["2257"],{"range":"2258","text":"2112"},["2259"],"Fast refresh only works when a file only exports components. Move your component(s) to a separate file. If all exports are HOCs, add them to the `extraHOCs` option.","localComponents","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/leonsilicon/Developer/github/leonsilicon/Chord/src/routes/chords/index.tsx:263:4\n  261 | \t\tconst targetProgress = state.isIndicatorVisible ? 1 : 0;\n  262 | \t\tif (Math.abs(targetProgress - startProgress) < 0.001) {\n> 263 | \t\t\tsetIndicatorProgress(targetProgress);\n      | \t\t\t^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  264 | \t\t\tindicatorProgressRef.current = targetProgress;\n  265 | \t\t\treturn;\n  266 | \t\t}","Do not call the 'set' function 'setIndicatorProgress' of 'useState' directly in 'useEffect'.","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/leonsilicon/Developer/github/leonsilicon/Chord/src/routes/chords/index.tsx:304:3\n  302 | \t\temitSurfaceRect();\n  303 | \t\tvoid emit('chorder-surface-ready');\n> 304 | \t\tsetIsPreparingSurface(false);\n      | \t\t^^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  305 | \t}, [isPreparingSurface, surfaceVersion]);\n  306 |\n  307 | \tuseEffect(() => {","Do not call the 'set' function 'setIsPreparingSurface' of 'useState' directly in 'useEffect'.","no-console","Unexpected console statement. Only these console methods are allowed: warn, error.","limited",["2260"],"antfu/no-top-level-await","Do not use top-level await","NoTopLevelAwait","Do not call the 'set' function 'setIsMobile' of 'useState' directly in 'useEffect'.","prefer-rest-params","Use the rest parameters instead of 'arguments'.","preferRestParams","no-sequences","Unexpected use of comma operator.","unexpectedCommaExpression","no-unused-expressions","Expected an assignment or function call and instead saw an expression.","unusedExpression","no-cond-assign","Unexpected assignment within ConditionalExpression.","'n' is defined but never used. Allowed unused args must match /^_/u.","unicorn/prefer-number-properties","Prefer `Number.isNaN` over `isNaN`.","error",["2261"],"regexp/no-unused-capturing-group","Capturing group number 1 is defined but never used.","unusedCapturingGroup",["2262"],"new-cap","A constructor name should not start with a lowercase letter.","lower","Unexpected assignment within an 'if' statement.","no-restricted-globals","Unexpected use of 'self'. Use `globalThis` instead.","customMessage","'t' is defined but never used. Allowed unused args must match /^_/u.","style/no-mixed-spaces-and-tabs","Mixed spaces and tabs.","mixedSpacesAndTabs","no-use-before-define","'Zn' was used before it was defined.","usedBeforeDefined","vars-on-top","All 'var' declarations must be at the top of the function scope.","top","no-var","Unexpected var, use let or const instead.","unexpectedVar","'tr' was used before it was defined.","regexp/no-super-linear-backtracking","The quantifier '[^;\"\\s]+' can exchange characters with '[^;\"\\s]*'. Using any string accepted by /=+/, this can be exploited to cause at least polynomial backtracking. This is going to cause exponential backtracking resulting in exponential worst-case runtime behavior.","trade","regexp/no-potentially-useless-backreference","Some paths leading to the backreference do not go through the referenced capturing group or the captured text might be reset before reaching the backreference.","potentiallyUselessBackreference","'p' was used before it was defined.","'h' was used before it was defined.","Unexpected assignment within a 'for' statement.","Unexpected assignment within a 'do...while' statement.","'H' was used before it was defined.","'e' is defined but never used. Allowed unused args must match /^_/u.","no-unused-vars","'R' is assigned a value but never used.",["2263"],"'R' is assigned a value but never used. Allowed unused vars must match /^_/u.","'l' is assigned a value but never used.",["2264"],"'l' is assigned a value but never used. Allowed unused vars must match /^_/u.","'c' was used before it was defined.","no-unreachable-loop","Invalid loop. Its body allows only one iteration.","invalid","'r' is assigned a value but never used.","'r' is assigned a value but never used. Allowed unused vars must match /^_/u.","'An' was used before it was defined.","'t' was used before it was defined.",["2265"],["2266"],"'jn' was used before it was defined.","'Bn' was used before it was defined.","'V' was used before it was defined.","'m' is assigned a value but never used.",["2267"],"'m' is assigned a value but never used. Allowed unused vars must match /^_/u.",["2268"],"'be' was used before it was defined.","ts/no-unsafe-function-type","The `Function` type accepts any function-like value.\nPrefer explicitly defining any function parameters and return type.","bannedFunctionType","unicorn/no-instanceof-builtins","Avoid using `instanceof` for type checking as it can lead to unreliable results.","no-instanceof-builtins",["2269"],["2270"],["2271"],["2272"],["2273"],"'ordinalOf' is assigned a value but never used. Allowed unused vars must match /^_/u.","Use \"@ts-expect-error\" instead of \"@ts-ignore\", as \"@ts-ignore\" will do nothing if the following line is error-free.","tsIgnoreInsteadOfExpectError",["2274"],["2275"],"node/pref