#!/bin/sh

set -eu

print_help() {
  cat <<'EOF'
Usage: chord <command>

Commands:
  settings
  open-settings
  show-settings
  reload-config
  reload-configs
  help

Examples:
  chord settings
  chord reload-configs
EOF
}

if [ "$#" -eq 0 ]; then
  print_help
  exit 0
fi

command_name="$1"

case "$command_name" in
  help|--help|-h)
    print_help
    exit 0
    ;;
  settings|open-settings|show-settings|reload-config|reload-configs)
    if ! output="$(open --background "chord:${command_name}" 2>&1)"; then
      if [ -n "$output" ]; then
        echo "$output" >&2
        echo >&2
      fi
      echo "Failed to open chord:${command_name}." >&2
      echo "Make sure the Chord app bundle has been built and opened at least once so macOS registers the chord: URL scheme." >&2
      exit 1
    fi
    exit 0
    ;;
  *)
    echo "Unknown command: $command_name" >&2
    echo >&2
    print_help >&2
    exit 1
    ;;
esac
